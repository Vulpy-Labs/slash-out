{
  "name": "slash-out",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run start:dev",
    "build": "npm run build --workspace client && npm run build --workspace server",
    "prepare": "node ./shared/scripts/git-hooks/setup-hooks.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
